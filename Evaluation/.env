# Boyue platform (OpenAI-compatible endpoint used for evaluation)
# Copy this file to `.env` and fill in the token below.
# NOTE: you wrote 3111/v1 but that port serves the Boyue web UI; the
# OpenAI-compatible gateway lives on port 3888. 3111 returns Next.js HTML 404
# for /v1/models and /v1/chat/completions, while 3888 serves both correctly.
BOYUE_BASE_URL=http://35.220.164.252:3888/v1
BOYUE_API_KEY=sk-ZnvhxhwyXok91ezpbDBcObLWa8GehlZtMaqnYT3ziVwhnBzC
# BOYUE_API_KEY=sk-IwNHTAnKOZvB1tdLt1z7l7xsE8Exa81qq5D2VujtemQGkBpc
# Optional: judge model for `essay` question_type. If unset, essay samples are
# skipped with error=essay_requires_judge_config (same as evaluation.score_one).
# Usually you can just reuse BOYUE_* here.
JUDGE_MODEL=gpt-4o
# Use the more stable HTTPS endpoint (via local proxy) for the essay judge.
# The old HTTP endpoint at 35.220.164.252 is intermittently unreachable and
# causes score_many to hang after answers are produced.
JUDGE_BASE_URL=https://api.boyuerichdata.opensphereai.com/v1
JUDGE_API_KEY=sk-ZnvhxhwyXok91ezpbDBcObLWa8GehlZtMaqnYT3ziVwhnBzC
# JUDGE_API_KEY=sk-IwNHTAnKOZvB1tdLt1z7l7xsE8Exa81qq5D2VujtemQGkBpc
# ---------------------------------------------------------------------------
# Path-C (full agent workflow) settings. Leave blank to fall back to the
# defaults documented in .env.example.
# ---------------------------------------------------------------------------
SCIVERSE_API_TOKEN=glpt_3bnwkx4eOUffyfq-SN7H-sF72sOYb349
BRIGHT_DATA_API_KEY=15c42205-6087-4e1b-8da8-18e6b722af1d
