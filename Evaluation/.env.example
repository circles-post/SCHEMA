# Boyue platform (OpenAI-compatible endpoint used for evaluation)
# Copy this file to `.env` and fill in the values below.
BOYUE_BASE_URL=
BOYUE_API_KEY=

# Optional: judge model for `essay` question_type. If unset, essay samples are
# skipped with error=essay_requires_judge_config (same as evaluation.score_one).
# Usually you can just reuse BOYUE_* here.
JUDGE_MODEL=
JUDGE_BASE_URL=
JUDGE_API_KEY=

# ---------------------------------------------------------------------------
# Path-C (full agent workflow) settings. Only read when runner is started
# with --use-tools (the default). All have working fallbacks so you can leave
# them blank and the full workflow still runs.
# ---------------------------------------------------------------------------

# sciverse_tools.literature_search / literature_fetch hit api.opendatalab.org.cn.
# If empty, the runner will load <path-to-sciverse-checkout>/.env (which is
# expected to contain SCIVERSE_API_TOKEN).
SCIVERSE_API_TOKEN=

# websearch_tools.web_search / web_fetch hit Bright Data's SERP proxy.
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_ZONE=

# ToolUniverse MCP server.
#   * Leave AGDEBUGGER_TOOLUNIVERSE_URL empty → the runner spawns a local
#     stdio server via scripts/run_tooluniverse_stdio.py (boot cost ~30–60s).
#   * Set it to an http(s) URL → the runner attaches to a shared
#     StreamableHttpServerParams endpoint (no boot cost). Matches the
#     AGDEBUGGER_TOOLUNIVERSE_URL behaviour in test_agent_debug.py.
AGDEBUGGER_TOOLUNIVERSE_URL=
