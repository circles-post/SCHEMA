{
  "project_name": "workflow_live_test",
  "env_file": ".env",
  "seed_keywords": [
    "Breast Cancer",
    "Bladder Cancer"
  ],
  "keyword_expansion": {
    "iterations": 1,
    "max_terms": 20,
    "min_term_length": 3,
    "heuristic_suffixes": [
      "diagnosis",
      "therapy"
    ],
    "manual_synonyms": {
      "bladder cancer": [
        "Urothelial Carcinoma"
      ],
      "breast cancer": [
        "Breast Neoplasms"
      ]
    },
    "generic_replacements": {
      "cancer": [
        "neoplasm"
      ]
    },
    "mesh": {
      "enabled": true,
      "base_url": "https://id.nlm.nih.gov/mesh",
      "limit": 2,
      "term_match_modes": [
        "exact"
      ],
      "match_modes": [
        "exact",
        "contains"
      ],
      "include_terms": true,
      "include_seealso": false,
      "include_qualifiers": false,
      "timeout": 20
    },
    "openai": {
      "enabled": false,
      "model": "intern-s1-pro",
      "base_url": "https://chat.intern-ai.org.cn/api/v1/",
      "max_terms_per_seed": 8,
      "thinking_mode": false,
      "temperature": 0.0,
      "max_tokens": 400
    }
  },
  "pubmed": {
    "api_key": "",
    "email": "test@example.com"
  },
  "crossref": {
    "enabled": true,
    "base_url": "https://api.crossref.org",
    "mailto": "test@example.com",
    "timeout": 30.0,
    "filter_has_abstract": false,
    "query_mode": "bibliographic"
  },
  "biorxiv": {
    "enabled": true,
    "base_url": "https://api.biorxiv.org",
    "jats_base_url": "https://www.biorxiv.org",
    "servers": [
      "biorxiv",
      "medrxiv"
    ],
    "interval_mode": "date_range",
    "start_date": "2020-01-01",
    "end_date": "2026-12-31",
    "recent_count": 500,
    "recent_days": 30,
    "max_pages_per_keyword": 2,
    "page_size": 100,
    "category": "",
    "timeout": 30.0
  },
  "retrieval": {
    "max_workers": 2,
    "retmax_per_keyword": 4,
    "crossref_query_mode": "bibliographic",
    "query_template": "(\"{keyword}\"[Title/Abstract] OR \"{keyword}\"[MeSH Terms]) AND english[Language]",
    "mindate": "2020/01/01",
    "maxdate": "2026/12/31",
    "sleep_seconds": 0.4,
    "journal_allowlist": [],
    "related_expand_limit": 2,
    "related_per_seed": 2
  },
  "scoring": {
    "semantic_weight": 0.7,
    "impact_weight": 0.3,
    "score_threshold": 0.03,
    "journal_impact_factors": {
      "Nature Medicine": 82.9,
      "The Lancet Oncology": 54.4,
      "Journal of Clinical Oncology": 45.3
    },
    "sapbert": {
      "enabled": true,
      "model_path": "<embeddings-dir>/SapBERT-from-PubMedBERT-fulltext",
      "batch_size": 4,
      "device": "cpu",
      "service_url": "http://<embedding-host>:8765",
      "remote_model": "sapbert",
      "request_timeout": 120.0,
      "verify_ssl": true
    }
  },
  "embedding": {
    "enabled": true,
    "model_path": "<embeddings-dir>/bge-large-en",
    "batch_size": 4,
    "device": "cpu",
    "instruction_prefix": "",
    "service_url": "http://<embedding-host>:8765",
    "remote_model": "bge",
    "request_timeout": 120.0,
    "verify_ssl": true
  },
  "fulltext": {
    "prefer_pmc": true,
    "abstract_fallback": true,
    "only_kept": true,
    "max_workers": 2,
    "prefer_crossref_landing_page": true,
    "crossref_landing_page_timeout": 20.0,
    "crossref_landing_page_min_chars": 1200
  },
  "paper_cache": {
    "enabled": true,
    "cache_dir": "./paper_cache",
    "store_pdf": true,
    "store_xml": true,
    "store_text": true,
    "store_landing_page": true
  },
  "chunking": {
    "chunk_words": 180,
    "overlap_words": 40
  },
  "graph": {
    "fusion_threshold": 0.88,
    "min_component_size": 2
  },
  "pdf_parsing": {
    "enabled": false,
    "backends": [
      "pdfplumber",
      "pymupdf",
      "pypdf"
    ]
  },
  "openai_extraction": {
    "enabled": true,
    "model": "intern-s1-pro",
    "base_url": "https://chat.intern-ai.org.cn/api/v1/",
    "confidence_threshold": 0.5,
    "thinking_mode": false,
    "temperature": 0.0,
    "max_tokens": 1200
  }
}
