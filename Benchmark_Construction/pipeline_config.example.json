{
  "project_name": "oncology_pubmed_graph_demo",
  "env_file": ".env",
  "seed_keywords": [
    "Bladder Cancer",
    "Breast Cancer"
  ],
  "keyword_expansion": {
    "iterations": 2,
    "max_terms": 200,
    "min_term_length": 3,
    "heuristic_suffixes": [
      "diagnosis",
      "treatment",
      "therapy",
      "biomarker",
      "screening",
      "prognosis"
    ],
    "manual_synonyms": {
      "bladder cancer": [
        "Urothelial Carcinoma",
        "Bladder Neoplasm",
        "Muscle-Invasive Bladder Cancer"
      ],
      "breast cancer": [
        "Mammary Carcinoma",
        "Triple Negative Breast Cancer",
        "HER2 Positive Breast Cancer"
      ]
    },
    "generic_replacements": {
      "cancer": [
        "neoplasm",
        "carcinoma",
        "oncology"
      ]
    },
    "mesh": {
      "enabled": true,
      "base_url": "https://id.nlm.nih.gov/mesh",
      "limit": 3,
      "term_match_modes": [
        "exact"
      ],
      "match_modes": [
        "exact",
        "contains"
      ],
      "include_terms": true,
      "include_seealso": true,
      "include_qualifiers": false,
      "timeout": 20
    },
    "openai": {
      "enabled": false,
      "model": "intern-s1-pro",
      "base_url": "https://chat.intern-ai.org.cn/api/v1/",
      "max_terms_per_seed": 8,
      "thinking_mode": false,
      "temperature": 0.0,
      "max_tokens": 400
    }
  },
  "pubmed": {
    "api_key": "",
    "email": "your_email@example.com"
  },
  "crossref": {
    "enabled": true,
    "base_url": "https://api.crossref.org",
    "mailto": "your_email@example.com",
    "timeout": 30.0,
    "filter_has_abstract": false,
    "query_mode": "bibliographic"
  },
  "retrieval": {
    "max_workers": 8,
    "retmax_per_keyword": 10,
    "crossref_query_mode": "bibliographic",
    "query_template": "(\"{keyword}\"[Title/Abstract] OR \"{keyword}\"[MeSH Terms]) AND english[Language]",
    "mindate": "2019/01/01",
    "maxdate": "2026/12/31",
    "sleep_seconds": 0.0,
    "journal_allowlist": [],
    "related_expand_limit": 10,
    "related_per_seed": 2
  },
  "scoring": {
    "semantic_weight": 0.7,
    "impact_weight": 0.3,
    "score_threshold": 0.2,
    "journal_impact_factors": {
      "Nature Medicine": 82.9,
      "The Lancet Oncology": 54.4,
      "Journal of Clinical Oncology": 45.3,
      "Cancer Discovery": 39.4,
      "Clinical Cancer Research": 13.4
    },
    "sapbert": {
      "enabled": true,
      "model_path": "/mnt/shared-storage-user/ai4good2-share/fengxinshun/embedding_models/SapBERT-from-PubMedBERT-fulltext",
      "batch_size": 8,
      "device": "cpu",
      "service_url": "http://100.99.247.97:8765",
      "remote_model": "sapbert",
      "request_timeout": 120.0,
      "verify_ssl": true
    }
  },
  "embedding": {
    "enabled": true,
    "model_path": "/mnt/shared-storage-user/ai4good2-share/fengxinshun/embedding_models/bge-large-en",
    "batch_size": 8,
    "device": "cpu",
    "instruction_prefix": "",
    "service_url": "http://100.99.247.97:8765",
    "remote_model": "bge",
    "request_timeout": 120.0,
    "verify_ssl": true
  },
  "fulltext": {
    "prefer_pmc": true,
    "abstract_fallback": true,
    "only_kept": true,
    "max_workers": 4,
    "prefer_crossref_landing_page": true,
    "crossref_landing_page_timeout": 20.0,
    "crossref_landing_page_min_chars": 1200
  },
  "paper_cache": {
    "enabled": true,
    "cache_dir": "/mnt/shared-storage-user/ai4good2-share/fengxinshun/datasetsa/paper_cache",
    "store_pdf": true,
    "store_xml": true,
    "store_text": true,
    "store_landing_page": true
  },
  "sciverse": {
    "enabled": false,
    "toolkit_root": "/mnt/shared-storage-user/fengxinshun/AISci/sciverse",
    "search_top_k": 5,
    "language": "en",
    "require_match": true,
    "min_title_token_overlap": 0.7
  },
  "chunking": {
    "chunk_words": 250,
    "overlap_words": 40
  },
  "graph": {
    "fusion_threshold": 0.88,
    "min_component_size": 2
  },
  "pdf_parsing": {
    "enabled": false,
    "backends": [
      "pdfplumber",
      "pymupdf",
      "pypdf"
    ]
  },
  "openai_extraction": {
    "enabled": true,
    "model": "intern-s1-pro",
    "base_url": "https://chat.intern-ai.org.cn/api/v1/",
    "confidence_threshold": 0.5,
    "thinking_mode": false,
    "temperature": 0.0,
    "max_tokens": 1200
  }
}
